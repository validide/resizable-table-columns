{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist/js/es6",
    "rootDir": "./sources/ts",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["sources/ts/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "coverage"]
}
